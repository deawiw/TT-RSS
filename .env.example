# Порт на хост-машине, по которому будет доступен веб-интерфейс TT-RSS.
TTRSS_HTTP_PORT=8280

# Полный адрес TT-RSS, который будет использовать само приложение.
TTRSS_SELF_URL_PATH=http://localhost:8280/

# Пароль для встроенного пользователя admin.
TTRSS_ADMIN_PASSWORD=change_me_admin_password

# Параметры PostgreSQL.
POSTGRES_DB=ttrss
POSTGRES_USER=ttrss
POSTGRES_PASSWORD=change_me_db_password

